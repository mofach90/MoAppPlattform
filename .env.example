# ── .env (local dev only, gitignored) ──────────────────────────────────────
# Firebase config (from Firebase console → Project settings → Your apps)
# These are public by design. For production, put them in .env.production
# (committed) instead. Only needed here for local dev.
VITE_API_KEY=
VITE_AUTH_DOMAIN=
VITE_PROJECT_ID=
VITE_STORAGEBUCKET=
VITE_MESSAGING_SENDER_ID=
VITE_APP_ID=
VITE_MEASUREMENT_ID=

# ── GitHub Actions Secret (never commit the real value) ────────────────────
# Only this email is allowed to log in. Set as a GitHub Actions secret named
# VITE_ALLOWED_EMAIL so the CI build can inject it without it being in git.
VITE_ALLOWED_EMAIL=
